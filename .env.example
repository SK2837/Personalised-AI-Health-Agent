# Copy this file to .env and fill in your keys.
# .env is gitignored so your secrets never leave your machine.

# --- Primary LLM (Groq, free tier) ---
# Get a key at https://console.groq.com (no credit card needed)
GROQ_API_KEY=your_groq_key_here

# --- Backup LLM (Google Gemini, free tier) ---
# Optional - get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Backup LLM (Cerebras Cloud, generous free tier) ---
# Optional - get a key at https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# --- Provider routing ---
# Which provider llm.py should call: groq | gemini | cerebras
LLM_PROVIDER=groq

# Model name within the chosen provider.
# Groq:     llama-3.3-70b-versatile  |  llama-3.1-8b-instant
# Gemini:   gemini-2.0-flash         |  gemini-2.0-flash-lite
# Cerebras: llama-3.3-70b            |  llama3.1-8b
LLM_MODEL=llama-3.3-70b-versatile
